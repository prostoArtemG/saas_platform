BOT_TOKEN=123456:your-telegram-bot-token
ADMIN_IDS=123456789,987654321
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/saas_platform
APP_HOST=0.0.0.0
APP_PORT=8000

# ----- Payments -------------------------------------------------------------
# Default provider when /api/create-payment-link omits "provider".
# One of: manual | mock | mono | liqpay
PAYMENT_PROVIDER_DEFAULT=manual

# Where the user is redirected after paying on the provider's page (optional).
PAYMENT_RETURN_URL=https://yourdomain.com/payment/success

# Public base URL of THIS app, used to build the server-to-server webhook URL.
# E.g. https://saas.yourdomain.com  -> webhook = {base}/api/payment-webhook/mono
PAYMENT_WEBHOOK_BASE_URL=https://saas.yourdomain.com

# Optional shared secret for the legacy /api/payment-request endpoint.
PAYMENT_WEBHOOK_SECRET=

# Monobank Acquiring (https://api.monobank.ua/docs/acquiring.html)
MONO_TOKEN=

# LiqPay (https://www.liqpay.ua/en/documentation/api)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
